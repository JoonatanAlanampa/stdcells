{
  "DESIGN_NAME": "tt_um_joonatanalanampa_cordic",
  "VERILOG_FILES": [
    "dir::cordic_gates.v"
  ],
  "SYNTH_ELABORATE_ONLY": true,
  "RUN_LINTER": false,
  "ERROR_ON_NL_ASSIGN_STATEMENTS": false,
  "CLOCK_PORT": "clk",
  "CLOCK_PERIOD": 20,
  "__comment_LIB": [
    "lib-v1.1: one timing view PER CORNER. Previously the single nominal",
    "own_hardening.lib was passed via EXTRA_LIBS, which LibreLane documents as",
    "'loaded indiscriminately for all timing corners' -- so all nine STA",
    "corners, and all nine SDF files, came out byte-identical. LIB is the",
    "corner-keyed variable (Dict[corner-pattern, List[Path]]); the sky130A PDK",
    "declares 9 corners = {nom,min,max} x {tt_025C_1v80, ss_100C_1v60,",
    "ff_n40C_1v95}, so the three patterns below cover them all. The hd libs",
    "are kept alongside ours because the flow still loads hd views even though",
    "EXTRA_EXCLUDED_CELLS keeps them out of the netlist.",
    "EXTRA_LIBS is retained ONLY so the yosys elaborate step can blackbox our",
    "cells; flow/check_corner_spread.py asserts the SDF corners really differ,",
    "which is what catches it if that nominal view ever overrides LIB."
  ],
  "LIB": {
    "*_tt_025C_1v80": [
      "pdk_dir::libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__tt_025C_1v80.lib",
      "dir::../out/own_hardening_tt_025C_1v80.lib"
    ],
    "*_ss_100C_1v60": [
      "pdk_dir::libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__ss_100C_1v60.lib",
      "dir::../out/own_hardening_ss_100C_1v60.lib"
    ],
    "*_ff_n40C_1v95": [
      "pdk_dir::libs.ref/sky130_fd_sc_hd/lib/sky130_fd_sc_hd__ff_n40C_1v95.lib",
      "dir::../out/own_hardening_ff_n40C_1v95.lib"
    ]
  },
  "EXTRA_LIBS": [
    "dir::../out/own_hardening.lib"
  ],
  "EXTRA_LEFS": [
    "dir::../out/own.lef"
  ],
  "EXTRA_GDS_FILES": [
    "dir::../out/own_cells.gds"
  ],
  "FP_SIZING": "absolute",
  "DIE_AREA": "0 0 161.00 111.52",
  "PL_TARGET_DENSITY_PCT": 85,
  "PL_RESIZER_HOLD_SLACK_MARGIN": 0.005,
  "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.005,
  "RUN_KLAYOUT_XOR": false,
  "RUN_KLAYOUT_DRC": false,
  "GRT_ALLOW_CONGESTION": true,
  "ERROR_ON_MAGIC_DRC": false,
  "ERROR_ON_ILLEGAL_OVERLAPS": false,
  "ERROR_ON_LVS_ERROR": false,
  "TOP_MARGIN_MULT": 1,
  "BOTTOM_MARGIN_MULT": 1,
  "LEFT_MARGIN_MULT": 2,
  "RIGHT_MARGIN_MULT": 2,
  "FP_WELLTAP_CELL": "WELLTAP_X1",
  "FP_ENDCAP_CELL": "FILL_X1",
  "FILL_CELL": [
    "FILL_X*"
  ],
  "DECAP_CELL": [
    "FILL_X*"
  ],
  "DIODE_CELL": "DIODE_X1/DIODE",
  "CTS_CLK_BUFFERS": [
    "BUF_X2",
    "BUF_X4"
  ],
  "CTS_ROOT_BUFFER": "BUF_X4",
  "EXTRA_EXCLUDED_CELLS": [
    "sky130_fd_sc_hd__*"
  ],
  "CTS_MAX_SLEW": 0.75,
  "CTS_MAX_CAP": 0.05
}